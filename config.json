  "telemetry": {
    "enabled": false,
    "endpoint": "https://telemetry.guardian-angel.app/v1/ingest",
    "send_interval_minutes": 60,
    "include_trigger_count": true,
    "include_fps_metrics": true,
    "include_error_logs": true,
    "include_device_specs": false,
    "user_id_anonymous": null
